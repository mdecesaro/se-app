{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Exercise Protocol Schema V3.0 (Binary v1.4.0)",
  "type": "object",
  "required": ["category", "modality", "parameters"],
  "properties": {
    "category": {
      "type": "string",
      "enum": ["Cognitive", "Coordination", "Conditioning", "Performance"]
    },
    "modality": {
      "type": "string",
      "enum": ["Single-Touch"]
    },
    "parameters": {
      "type": "object",
      "required": [
        "game_mode",
        "game_rounds",
        "game_attempts",
        "target_qty",
        "target_logic",
        "target_rgb_hex",
        "dist_mode",
        "dist_qty",
        "dist_behavior",
        "dist_rgbs_hex",
        "delay_type",
        "delay_min_ms",
        "delay_max_ms",
        "timeout_ms",
        "repeat_if_wrong"
      ],
      "additionalProperties": false,
      "properties": {
        "game_mode": { "type": "integer", "enum": [1, 2], "description": "1: Random, 2: Pattern (1 byte)" },
        "game_rounds": { "type": "integer", "minimum": 1, "maximum": 255, "description": "Total game rounds (1 byte)" },
        "game_attempts": { "type": "integer", "minimum": 1, "maximum": 255, "description": "Strikes allowed per target (1 byte)" },
        "target_qty": { "type": "integer", "minimum": 1, "maximum": 255, "description": "Stimuli count per round (1 byte)" },
        "target_logic": { "type": "integer", "minimum": 0, "maximum": 255, "description": "Actuation logic rule (1 byte)" },
        "target_rgb_hex": {
          "type": "string",
          "pattern": "^#([A-Fa-f0-9]{6})$",
          "description": "HEX color including # (3 bytes parsed)"
        },
        "dist_mode": { "type": "integer", "minimum": 0, "maximum": 255, "description": "Distraction algorithm mode (1 byte)" },
        "dist_qty": { "type": "integer", "minimum": 0, "maximum": 3, "description": "Number of distractor pods (1 byte)" },
        "dist_behavior": { "type": "integer", "minimum": 0, "maximum": 255, "description": "Reaction on wrong hit (1 byte)" },
        "dist_rgbs_hex": {
          "type": "array",
          "maxItems": 3,
          "items": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6})$" },
          "description": "Array of up to 3 distractor HEX colors. Empty array [] if dist_qty is 0 (9 bytes total)"
        },
        "delay_type": { "type": "integer", "enum": [1, 2], "description": "1: Fixed, 2: Range (1 byte)" },
        "delay_min_ms": { "type": "integer", "minimum": 0, "maximum": 65535, "description": "Min delay in milliseconds (2 bytes)" },
        "delay_max_ms": { "type": "integer", "minimum": 0, "maximum": 65535, "description": "Max delay in milliseconds (2 bytes)" },
        "timeout_ms": { "type": "integer", "minimum": 0, "maximum": 65535, "description": "Max time allowed per target (2 bytes)" },
        "repeat_if_wrong": { "type": "boolean", "description": "True converts to 0x01, False to 0x00 (1 byte)" }
      }
    }
  }
}