{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Exercise Protocol Schema V2.4",
  "type": "object",
  "required": ["category", "modality", "parameters"],
  "properties": {
    "category": {
      "type": "string",
      "enum": ["Cognitive", "Coordination", "Conditioning", "Performance"]
    },
    "modality": {
      "type": "string",
      "enum": ["Single-Touch"]
    },
    "parameters": {
      "type": "object",
      "required": [
        "stimuli_count",
        "stimuli_rounds",
        "stimuli_mode",
        "stimuli_color",
        "dist_qty",
        "dist_colors",
        "delay_type",
        "delay_min",
        "delay_max",
        "timeout_ms",
        "repeat_if_wrong"
      ],
      "properties": {
        "stimuli_count": { "type": "integer", "minimum": 1 },
        "stimuli_rounds": { "type": "integer", "minimum": 1 },
        "stimuli_mode": {
          "type": "integer",
          "enum": [1, 2],
          "description": "1: Random, 2: Pattern"
        },
        "stimuli_color": {
          "type": "string",
          "pattern": "^#([A-Fa-f0-9]{6})$",
          "description": "HEX color including #"
        },
        "dist_qty": { "type": "integer", "minimum": 0, "maximum": 3 },
        "dist_colors": {
          "oneOf": [
            { "type": "integer", "enum": [0], "description": "Set to 0 if dist_qty is 0" },
            {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6})$" }
            }
          ]
        },
        "delay_type": {
          "type": "integer",
          "enum": [1, 2],
          "description": "1: Fixed, 2: Range"
        },
        "delay_min": { "type": "integer", "minimum": 0 },
        "delay_max": { "type": "integer", "minimum": 0 },
        "timeout_ms": { "type": "integer", "minimum": 0 },
        "repeat_if_wrong": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}